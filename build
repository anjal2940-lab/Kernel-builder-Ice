#!/bin/sh

# ==================================================
#           Ice Kernel Build Script (Redmi A1)
# ==================================================

set -e

# --- Configuration ---
KERNEL_SOURCE="https://github.com/anjal2940-lab/Ice-kernel-source"
KERNEL_BRANCH="main"
KERNEL_DEFCONFIG="ice_defconfig" # Ensure this config file supports 32-bit inside arch/arm/configs/

# --- Paths ---
WORK="${GITHUB_WORKSPACE}"
KERNEL_SRC="${WORK}/myKernel"
LOG_FILE="${WORK}/build.log"

# --- Setup Environment ---
echo ">> Setting up dependencies..."
[ ! -d "${WORK}/clang" ] && git clone --depth=1 https://github.com/techyminati/android_prebuilts_clang_host_linux-x86_clang-6443078 "${WORK}/clang"
[ ! -d "${WORK}/x64" ] && git clone --depth=1 https://github.com/KudProject/aarch64-linux-android-4.9 "${WORK}/x64"
[ ! -d "${WORK}/x32" ] && git clone --depth=1 https://github.com/KudProject/arm-linux-androideabi-4.9 "${WORK}/x32"

export PATH="${WORK}/clang/bin:${WORK}/x64/bin:${WORK}/x32/bin:${PATH}"

# CHANGED: Shift target system global architecture from arm64 to arm
export ARCH=arm

echo ">> Cloning Kernel Source..."
rm -rf "${KERNEL_SRC}"
git clone --depth=1 "${KERNEL_SOURCE}" -b "${KERNEL_BRANCH}" "${KERNEL_SRC}"

# --- Build Function ---
build_kernel() {
    echo ">> Starting Compilation..."
    cd "${KERNEL_SRC}"
    
    # Capture build process to log file
    {
        # CHANGED: Build target directory flags flipped from arm64 to arm
        make O=out ARCH=arm "${KERNEL_DEFCONFIG}"
        make -j"$(nproc --all)" O=out \
             ARCH=arm \
             CC=clang \
             CLANG_TRIPLE=arm-linux-gnueabi- \
             CROSS_COMPILE=arm-linux-androideabi-
    } 2>&1 | tee "${LOG_FILE}"
}

# --- Execution ---
if build_kernel; then
    echo ">> Success: Kernel compiled successfully!"
    # CHANGED: Final binary outputs paths update to the 32-bit zImage format destination directory
    echo ">> Your compiled build files are available in: ${KERNEL_SRC}/out/arch/arm/boot/"
else
    echo "!! Build Failed. Check build.log"
    exit 1
fi
