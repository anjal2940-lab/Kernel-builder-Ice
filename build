#!/bin/sh

# ==================================================
#           Lotus Kernel Build Script
# ==================================================

set -e

# --- Configuration ---
KERNEL_SOURCE="https://github.com/ansh-m14x/Kernel_CPH2015"
KERNEL_BRANCH="lotus-kernel"
KERNEL_DEFCONFIG="19581_defconfig"

# --- Paths ---
WORK="${GITHUB_WORKSPACE}"
DATE=$(date +"%Y%m%d-%H")
ANYKERNEL_DIR="${WORK}/AK3_Final"

# --- Setup Environment ---
echo ">> Setting up dependencies..."
[ ! -d "${WORK}/clang" ] && git clone --depth=1 https://github.com/crdroidandroid/android_prebuilts_clang_host_linux-x86_clang-5407736 "${WORK}/clang"
[ ! -d "${WORK}/x64" ] && git clone --depth=1 https://github.com/KudProject/aarch64-linux-android-4.9 "${WORK}/x64"
[ ! -d "${WORK}/x32" ] && git clone --depth=1 https://github.com/KudProject/arm-linux-androideabi-4.9 "${WORK}/x32"
[ ! -d "${WORK}/AK_Repo" ] && git clone --depth=1 https://github.com/ansh-m14x/Action-Kernel-Builder "${WORK}/AK_Repo"

export PATH="${WORK}/clang/bin:${WORK}/x64/bin:${WORK}/x32/bin:${PATH}"
export ARCH=arm64

# --- Automatically find the Kernel Source ---
KERNEL_SRC=$(find "${WORK}" -type d -name "arch" | grep -m1 "arm64" | sed 's|/arch/arm64||')

# Fallback: if not found by find, try the standard clone path
if [ -z "${KERNEL_SRC}" ]; then
    echo ">> Kernel source not found via search, cloning..."
    KERNEL_SRC="${WORK}/myKernel"
    git clone --depth=1 "${KERNEL_SOURCE}" -b "${KERNEL_BRANCH}" "${KERNEL_SRC}"
fi

echo ">> Found Kernel Source at: ${KERNEL_SRC}"

# --- Build Function ---
build_kernel() {
    echo ">> Starting Compilation..."
    cd "${KERNEL_SRC}"
    make O=out ARCH=arm64 "${KERNEL_DEFCONFIG}"
    make -j"$(nproc --all)" O=out \
         ARCH=arm64 \
         CC=clang \
         CLANG_TRIPLE=aarch64-linux-gnu- \
         CROSS_COMPILE=aarch64-linux-android- \
         CROSS_COMPILE_ARM32=arm-linux-androideabi-
}

# --- Package Function ---
package_zip() {
    echo ">> Creating Flashable ZIP..."
    rm -rf "${ANYKERNEL_DIR}"
    mkdir -p "${ANYKERNEL_DIR}"
    
    # Copy AnyKernel files
    cp -r "${WORK}/AK_Repo/any-kernel(OP4C7D)/"* "${ANYKERNEL_DIR}/"
    
    # Copy kernel image
    cp "${KERNEL_SRC}/out/arch/arm64/boot/Image.gz-dtb" "${ANYKERNEL_DIR}/"
    
    cd "${ANYKERNEL_DIR}"
    zip -r9 "Lotus-Kernel-${DATE}.zip" ./* || { echo "!! Zip creation failed"; exit 1; }
    
    # Move zip to root so GitHub Actions finds it easily
    mv "Lotus-Kernel-${DATE}.zip" "${WORK}/"
    echo ">> Success: Lotus-Kernel-${DATE}.zip is ready!"
}

# --- Execution ---
if build_kernel; then
    package_zip
else
    echo "!! Build Failed."
    exit 1
fi
