#!/bin/sh

# ==================================================
#           Lotus Kernel Build Script
# ==================================================

set -e

# --- Configuration ---
KERNEL_SOURCE="https://github.com/ansh-m14x/Kernel_CPH2015"
KERNEL_BRANCH="RKSU"
KERNEL_DEFCONFIG="19581_defconfig"

# --- Paths ---
WORK="${GITHUB_WORKSPACE}"
DATE=$(date +"%Y%m%d-%H")
ANYKERNEL_DIR="${WORK}/AK3_Final"

# --- Setup Environment ---
echo ">> Checking for local dependencies..."
# No longer cloning; assuming these directories exist in your repo
if [ ! -d "${WORK}/clang" ]; then echo "!! Error: Clang folder missing"; exit 1; fi
if [ ! -d "${WORK}/x64" ]; then echo "!! Error: x64 toolchain missing"; exit 1; fi
if [ ! -d "${WORK}/x32" ]; then echo "!! Error: x32 toolchain missing"; exit 1; fi
if [ ! -d "${WORK}/AK_Repo" ]; then echo "!! Error: AK_Repo missing"; exit 1; fi

export PATH="${WORK}/clang/bin:${WORK}/x64/bin:${WORK}/x32/bin:${PATH}"
export ARCH=arm64

# --- Automatically find the Kernel Source ---
KERNEL_SRC=$(find "${WORK}" -maxdepth 2 -type d -name "arch" | head -n 1 | sed 's|/arch||')

if [ -z "${KERNEL_SRC}" ]; then
    echo "!! Error: Kernel source directory not found!"
    exit 1
fi

echo ">> Found Kernel Source at: ${KERNEL_SRC}"

# --- Build Function ---
build_kernel() {
    echo ">> Starting Compilation..."
    cd "${KERNEL_SRC}"
    make O=out ARCH=arm64 "${KERNEL_DEFCONFIG}"
    make -j"$(nproc --all)" O=out \
         ARCH=arm64 \
         CC=clang \
         CLANG_TRIPLE=aarch64-linux-gnu- \
         CROSS_COMPILE=aarch64-linux-android- \
         CROSS_COMPILE_ARM32=arm-linux-androideabi-
}

# --- Package Function ---
package_zip() {
    echo ">> Creating Flashable ZIP..."
    rm -rf "${ANYKERNEL_DIR}"
    mkdir -p "${ANYKERNEL_DIR}"
    
    # Copy AnyKernel files from your local repo
    cp -r "${WORK}/AK_Repo/any-kernel(OP4C7D)/"* "${ANYKERNEL_DIR}/"
    
    # Copy kernel image
    cp "${KERNEL_SRC}/out/arch/arm64/boot/Image.gz-dtb" "${ANYKERNEL_DIR}/"
    
    cd "${ANYKERNEL_DIR}"
    zip -r9 "Lotus-Kernel-${DATE}.zip" ./* || { echo "!! Zip creation failed"; exit 1; }
    
    # Move zip to root
    mv "Lotus-Kernel-${DATE}.zip" "${WORK}/"
    echo ">> Success: Lotus-Kernel-${DATE}.zip is ready!"
}

# --- Execution ---
# Redirect output to build.log for your release
if build_kernel 2>&1 | tee "${WORK}/build.log"; then
    package_zip
else
    echo "!! Build Failed."
    exit 1
fi
